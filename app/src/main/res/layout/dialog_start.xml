<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="위키 선택"
        android:textSize="11sp"
        android:textColor="@color/muted"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="10dp" />

    <!-- 위키 선택 (2x3 그리드) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/wikiNamu"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇰🇷 나무위키" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />

        <Button android:id="@+id/wikiEn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇺🇸 English" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginStart="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <Button android:id="@+id/wikiKo"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇰🇷 한국어 위키" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />

        <Button android:id="@+id/wikiJa"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇯🇵 日本語" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginStart="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <Button android:id="@+id/wikiDe"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇩🇪 Deutsch" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginEnd="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />

        <Button android:id="@+id/wikiFr"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:text="🇫🇷 Français" android:textSize="12sp" android:textColor="@color/text"
            android:layout_marginStart="4dp"
            style="@style/Widget.Material3.Button.OutlinedButton" android:strokeColor="@color/border" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="난이도 선택"
        android:textSize="11sp"
        android:textColor="@color/muted"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:layout_marginBottom="10dp" />

    <!-- 난이도 카드 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <LinearLayout android:id="@+id/diffEasy"
            android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_diff_card" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🟢" android:textSize="18sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="쉬움" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text" />
        </LinearLayout>

        <LinearLayout android:id="@+id/diffMedium"
            android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_diff_card" android:layout_marginStart="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🟡" android:textSize="18sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="보통" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/diffHard"
            android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_diff_card" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔴" android:textSize="18sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="어려움" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text" />
        </LinearLayout>

        <LinearLayout android:id="@+id/diffVeryHard"
            android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:background="@drawable/bg_diff_hard" android:layout_marginStart="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💀" android:textSize="18sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="최고난도" android:textSize="13sp" android:textStyle="bold" android:textColor="@color/danger" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
